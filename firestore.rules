rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read/write their own chat data
    match /chats/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Collection-group reads on `messages` for the search path. Each message
    // doc carries a `userId` field (denormalized in addMessage); only the
    // owning user can read their own messages via collectionGroup queries.
    match /{path=**}/messages/{messageId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Allow authenticated users to read/write their own user data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for prompts
    match /prompts/{userId}/userPrompts/{promptId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
